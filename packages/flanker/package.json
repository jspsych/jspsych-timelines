{
    "name": "@jspsych-timelines/flanker",
    "version": "0.0.1",
    "description": "Eriksen Flanker Task for measuring inhibitory control and selective attention.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "unpkg": "dist/index.browser.js",
    "scripts": {
        "build": "tsup src/index.ts --format esm,iife,cjs --sourcemap --dts --treeshake --clean --global-name jsPsychTimelineFlanker --inject-style && node -e \"require('fs').renameSync('dist/index.global.js','dist/index.browser.js')\" && node -e \"require('fs').renameSync('dist/index.global.js.map','dist/index.browser.js.map')\""
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jspsych/jspsych-timelines.git",
        "directory": "packages/flanker"
    },
    "keywords": [
        "jsPsych",
        "flanker",
        "executive function",
        "inhibitory control",
        "attention"
    ],
    "author": {
        "name": "Josh de Leeuw",
        "url": "https://github.com/jodeleeuw"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jspsych/jspsych-timelines/issues"
    },
    "homepage": "https://github.com/jspsych/jspsych-timelines/tree/main/packages/flanker#readme",
    "peerDependencies": {
        "jspsych": ">=8.0.0"
    },
    "devDependencies": {
        "@jspsych/config": "^3.2.2",
        "jspsych": "^8.0.0",
        "tsup": "^6.7.0",
        "typescript": "^5.0.2"
    },
    "dependencies": {
        "@jspsych/plugin-html-button-response": "^2.1.0",
        "@jspsych/plugin-html-keyboard-response": "^2.1.0"
    }
}
