{
    "name": "@jspsych-timelines/speeded-matching",
    "version": "0.0.1",
    "description": "An assessment of processing speed. Participants are asked to identify which of a selection of pictures matches the target picture at the top of the screen.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "unpkg": "dist/index.global.js",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./styles.css": "./dist/css/styles.css"
    },
    "files": [
      "src",
      "dist"
    ],
    "scripts": {
      "build": "tsup src/index.ts --format esm,iife,cjs --sourcemap --dts --treeshake --clean --global-name jsPsychTimelineSpeededMatching && node -e \"require('fs').mkdirSync('dist/css', {recursive:true}); require('fs').copyFileSync('src/styles.css', 'dist/css/styles.css')\"",
      "test": "jest"
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/jspsych/jspsych-timelines",
      "directory": "packages/speeded-matching"
    },
    "keywords": [
      "jsPsych"
    ],
    "contributors": [
      {
        "name": "Abdullah Hunter Farhat",
        "url": "https://github.com/farhat60"
      }
    ],
    "license": "MIT",
    "bugs": {
      "url": "https://github.com/jspsych/jspsych-timelines/issues"
    },
    "homepage": "/@jspsych-timelines/speeded-matching/README.md",
    "devDependencies": {
      "@jspsych/config": "^3.2.2",
      "@types/jest": "^29.5.0",
      "jest": "^29.5.0",
      "jest-environment-jsdom": "^29.5.0",
      "jspsych": "^8.0.0",
      "ts-jest": "^29.1.0",
      "tsup": "^6.7.0",
      "typescript": "^5.0.2"
    },
    "dependencies": {
        "@jspsych/plugin-html-button-response": "^2.1.0",
        "@jspsych/plugin-instructions": "^2.1.0"
    }
  }