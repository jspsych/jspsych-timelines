{
    "name": "@jspsych-timelines/simple-rt",
    "version": "0.0.1",
    "description": "Simple Reaction Time task for measuring basic response speed.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "unpkg": "dist/index.browser.js",
    "scripts": {
        "build": "tsup src/index.ts --format esm,iife,cjs --sourcemap --dts --treeshake --clean --global-name jsPsychTimelineSimpleRT --inject-style && node -e \"require('fs').renameSync('dist/index.global.js','dist/index.browser.js')\" && node -e \"require('fs').renameSync('dist/index.global.js.map','dist/index.browser.js.map')\"",
        "test": "jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jspsych/jspsych-timelines.git",
        "directory": "packages/simple-rt"
    },
    "keywords": [
        "jsPsych",
        "reaction time",
        "simple RT",
        "response speed"
    ],
    "author": {
        "name": "Josh de Leeuw",
        "url": "https://github.com/jodeleeuw"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jspsych/jspsych-timelines/issues"
    },
    "homepage": "https://github.com/jspsych/jspsych-timelines/tree/main/packages/simple-rt#readme",
    "peerDependencies": {
        "jspsych": ">=8.0.0"
    },
    "devDependencies": {
        "@jspsych/config": "^3.2.2",
        "@jspsych/test-utils": "^1.0.0",
        "jest": "^29.0.0",
        "jspsych": "^8.0.0",
        "ts-jest": "^29.0.0",
        "tsup": "^6.7.0",
        "typescript": "^5.0.2"
    },
    "dependencies": {
        "@jspsych/plugin-html-button-response": "^2.1.0"
    }
}
